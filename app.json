{
  "expo": {
    "name": "Vitora",
    "slug": "vitora",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0d0d14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vitora.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0d14"
      },
      "package": "com.vitora.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset"
    ],
    "scheme": "vitora",
    "experiments": {
      "typedRoutes": true
    }
  }
}
